# Shared HS256 secret. MUST match NEXTAUTH_JWT_SECRET on the backend — this is
# how the backend verifies dashboard requests. Generate with:
#   openssl rand -base64 48
AUTH_SECRET=dev-secret-change-me-openssl-rand-base64-48

# Base URL the backend FastAPI service is reachable at from the Next.js server.
# In local dev this is the uvicorn process; in prod this is the Railway URL.
BACKEND_URL=http://localhost:8000

# Optional: Auth.js needs to know its own URL in production so it can build
# absolute callback URLs. Leave unset in dev (defaults to http://localhost:3100).
# AUTH_URL=https://dashboard.example.com
