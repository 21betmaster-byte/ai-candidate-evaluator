# Database
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/evaluator

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
SONNET_MODEL=claude-sonnet-4-6
OPUS_MODEL=claude-opus-4-6

# Gmail OAuth (generate via Google OAuth Playground or a one-shot helper)
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_ADDRESS=hiring@yourdomain.com
GMAIL_LABEL_PROCESSED=evaluator/processed

# GitHub (optional but strongly recommended to avoid rate limits)
GITHUB_TOKEN=

# Worker
WORKER_POLL_INTERVAL_SECONDS=5
INBOX_POLL_INTERVAL_MINUTES=2

# Dashboard auth
# Empty ALLOWED_EMAILS = dev mode (no auth). Otherwise backend requires an
# Authorization: Bearer <HS256 JWT> whose `email` claim is in this list.
# NEXTAUTH_JWT_SECRET must equal the dashboard's AUTH_SECRET (Auth.js v5),
# and the dashboard must override jwt.encode/decode to sign HS256 (not JWE).
# See backend/app/auth.py for the full contract.
ALLOWED_EMAILS=you@yourdomain.com
NEXTAUTH_JWT_SECRET=

# Branding
COMPANY_NAME=Plum
